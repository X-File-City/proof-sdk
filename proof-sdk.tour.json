{
  "id": "proof-sdk-onboarding",
  "title": "Proof SDK: Collaborative Editor with AI Agent Bridge",
  "description": "A guided tour of the Proof SDK — an open-source collaborative markdown editor with provenance tracking, real-time collaboration, and an HTTP bridge for AI agents.",
  "version": "1.0.0",
  "audience": "New Contributors & Integrators",
  "prerequisites": [
    "Familiarity with TypeScript and Node.js",
    "Basic understanding of collaborative editing concepts (CRDTs, Yjs)"
  ],
  "steps": [
    {
      "id": "step-1-overview",
      "title": "Welcome to Proof SDK",
      "description": "Proof SDK is an open-source collaborative markdown editor with provenance tracking and an AI agent bridge. The project is organized as a monorepo with npm workspaces: reusable SDK packages live in `packages/`, the editor and agent runtime in `src/`, the Express server in `server/`, and documentation in `docs/`. Let's explore each layer.",
      "estimatedTime": 60,
      "colorMode": "fileTypes",
      "focusDirectory": "",
      "highlightLayers": [
        {
          "id": "top-level-config",
          "name": "Root Configuration",
          "color": "#94a3b8",
          "items": [
            { "path": "package.json", "type": "file" },
            { "path": "tsconfig.json", "type": "file" },
            { "path": "vite.config.ts", "type": "file" }
          ],
          "opacity": 0.6,
          "renderStrategy": "border"
        }
      ]
    },
    {
      "id": "step-2-packages",
      "title": "SDK Packages (packages/)",
      "description": "Five SDK packages form the reusable core: proof/core (types & marks), proof/editor (Milkdown plugins), proof/server (Express routers), proof/sqlite (storage), and proof/agent-bridge (typed HTTP client). Each has a barrel export and can be independently consumed.",
      "estimatedTime": 90,
      "focusDirectory": "packages",
      "colorMode": "fileTypes",
      "highlightLayers": [
        {
          "id": "core-pkg",
          "name": "proof/core",
